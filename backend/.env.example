# ==========================================
# Smart Mining Safety Belt - Backend Config
# Copy this file to ".env" and fill in values
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local:  mongodb://127.0.0.1:27017/smart_mining_safety_belt
# Atlas:  mongodb+srv://<user>:<password>@cluster0.mongodb.net/smart_mining_safety_belt
MONGO_URI=mongodb://127.0.0.1:27017/smart_mining_safety_belt

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Default control-room login (seeded)
ADMIN_EMAIL=admin@safetybelt.com
ADMIN_PASSWORD=Admin@123

# CORS - frontend origin
CLIENT_URL=http://localhost:5173

# Sensor Simulation Engine
SIMULATION_ENABLED=true
SIMULATION_INTERVAL_MS=3000
SIMULATION_ANOMALY_CHANCE=0.08

# Safety Thresholds
THRESHOLD_CO_PPM=50
THRESHOLD_CH4_PERCENT=1.0
THRESHOLD_O2_MIN_PERCENT=19.5
THRESHOLD_HEART_RATE_MIN=20
THRESHOLD_HEART_RATE_MAX=100
THRESHOLD_BODY_TEMP_MAX=38.5
THRESHOLD_BATTERY_LOW=15
